# ===== Homebox 连接 =====
HOMEBOX_URL=https://homebox.example.com:666
HOMEBOX_TOKEN=
HOMEBOX_EMAIL=
HOMEBOX_PASSWORD=
HOMEBOX_LOCATION_ID=

# 会话签名密钥（APP_SECRET）：用于给登录 cookie 签名，固定值避免重启后强制登出
# 可用 `python -c "import secrets;print(secrets.token_hex(32))"` 生成
APP_SECRET=

# ===== 商品数据源 =====
# Open Food Facts 免费，无需配置，默认开启。
# 腾讯云市场官方 GS1 接口（中国物品编码中心数据），国货/非食品兜底。
# 在腾讯云市场购买「商品条码查询」后填入：
# https://market.cloud.tencent.com/products/20577
GS1_API_URL=http://ap-guangzhou.cloudmarket-apigw.com/service-8lp6ruw0/getBarcode
GS1_SECRET_ID=
GS1_SECRET_KEY=

# ===== AI 识图兜底（可选）=====
# 完全查不到条码时，调用 OpenAI 兼容视觉接口识别包装图。
VISION_API_URL=
VISION_API_KEY=
VISION_MODEL=gpt-4o-mini
